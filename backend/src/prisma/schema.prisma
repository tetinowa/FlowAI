// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "./generated"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_PUBLIC_URL")
}

model Organization {
  id          String    @id @unique
  name        String    @default("")   // ← @default нэмэх
  members     Client[]
  industry    Industry
  financeData      Finance[]
  financeAnalyses  FinanceAnalysis[]
  posts            Post[]
  createdAt   DateTime  @default(now())
}

enum Industry {
  TECH
  FINANCE
  HEALTHCARE
  EDUCATION
  RETAIL
  MANUFACTURING
}

model Client {
  id        String           @id @unique
  ofOrg     Organization     @relation(fields: [orgId], references: [id])
  orgId     String
  role      MemberAccessType
  email     String
  firstname String
  lastname  String
  createdAt DateTime         @default(now())
}

enum MemberAccessType {
  EXECUTIVE
  MANAGEMENT
  MEMBER
}

model Finance {
  id        String       @id @default(cuid())  // ← @id болгох
  org       Organization @relation(fields: [orgId], references: [id])
  orgId     String                              // ← @id хасах
  month     DateTime?                          // ← нэмэх
  balance   Int?
  revenue   Int?
  expense   Int?
  netProfit Int?
  margin    Int?
}

enum ExpenseType {
  БАРАА_МАТЕРИАЛ
  ТЭЭВЭР
  УРСГАЛ_ЗАРДАЛ
  ЦАЛИН
}

model FinanceAnalysis {
  id         String       @id @default(cuid())
  org        Organization @relation(fields: [orgId], references: [id])
  orgId      String
  summary    String
  categories Json
  tips       Json
  createdAt  DateTime     @default(now())
}

model Post {
  id          String       @id @default(cuid())
  org         Organization @relation(fields: [orgId], references: [id])
  orgId       String
  title       String
  content     String       @default("")
  platform    String
  reach       Int          @default(0)
  publishedAt DateTime     @default(now())
}
