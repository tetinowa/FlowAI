generator client {
  provider = "prisma-client-js"
  output   = "./generated"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_PUBLIC_URL")
}

model Organization {
  id                   String            @id @unique
  name                 String            @default("")
  industry             Industry
  patronage            Subscription      @default(BASIC)
  stripeCustomerId     String?
  stripeSubscriptionId String?
  createdAt            DateTime          @default(now())
  members              Client[]
  financeData          Finance[]
  financeAnalyses      FinanceAnalysis[]
  posts                Post[]
}

model Client {
  id         String           @id @unique
  orgId      String?
  role       MemberAccessType
  email      String
  firstname  String
  lastname   String
  profilePic String?
  createdAt  DateTime         @default(now())
  ofOrg      Organization?    @relation(fields: [orgId], references: [id])
}

model Finance {
  id        String       @id @default(cuid())
  orgId     String
  month     DateTime?
  balance   Int?
  revenue   Int?
  expense   Int?
  netProfit Int?
  margin    Int?
  org       Organization @relation(fields: [orgId], references: [id])
}

model FinanceAnalysis {
  id         String       @id @default(cuid())
  orgId      String
  summary    String
  categories Json
  monthly    Json?
  tips       Json
  createdAt  DateTime     @default(now())
  org        Organization @relation(fields: [orgId], references: [id])
}

model Post {
  id          String       @id @default(cuid())
  orgId       String
  title       String
  content     String       @default("")
  platform    String
  reach       Int          @default(0)
  published   Boolean      @default(false)
  publishedAt DateTime     @default(now())
  org         Organization @relation(fields: [orgId], references: [id])
}

model Administrator {
  id             String   @id @unique
  email          String
  username       String   @unique
  password       String
  createdAt      DateTime @default(now())
  lastAccessTime DateTime @default(now())
}

enum Industry {
  TECH
  FINANCE
  HEALTHCARE
  EDUCATION
  RETAIL
  MANUFACTURING
}

enum MemberAccessType {
  EXECUTIVE
  MANAGEMENT
  MEMBER
}

enum ExpenseType {
  БУСАД
}

enum Subscription {
  BASIC
  PRO
}
